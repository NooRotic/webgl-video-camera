{
  "name": "@riptheai/webgl-video",
  "version": "0.1.0",
  "description": "Three.js WebGL video texture components for React — webcam cubes, spheres, shader effects, VHS filters, video grids, and tile animations",
  "author": "RipTheAI",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./animations": {
      "types": "./dist/core/GridAnimations.d.ts",
      "import": "./dist/core/GridAnimations.js",
      "require": "./dist/core/GridAnimations.cjs"
    }
  },
  "files": [
    "dist",
    "src",
    "assets",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "dev:lib": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "three": ">=0.150.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.171.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.171.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^3.0.0",
    "jsdom": "^25.0.0",
    "vite": "^6.0.0",
    "@vitejs/plugin-react": "^4.0.0"
  },
  "keywords": [
    "webgl",
    "three.js",
    "video",
    "webcam",
    "react",
    "3d",
    "shader",
    "video-texture",
    "camera",
    "vhs",
    "glsl",
    "animation"
  ],
  "license": "MIT",
  "homepage": "https://github.com/NooRotic/webgl-video-camera#readme",
  "bugs": {
    "url": "https://github.com/NooRotic/webgl-video-camera/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/NooRotic/webgl-video-camera.git"
  }
}
